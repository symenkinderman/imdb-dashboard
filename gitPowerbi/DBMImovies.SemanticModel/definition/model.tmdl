model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-CA
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["acteurs_tabel","regisseurs_tabel","film_acteurs","genres_tabel","film_genres","films_tabel"]

annotation PBI_ProTooling = ["DevMode"]

ref table acteurs_tabel
ref table regisseurs_tabel
ref table film_acteurs
ref table genres_tabel
ref table film_genres
ref table films_tabel

ref cultureInfo en-US

